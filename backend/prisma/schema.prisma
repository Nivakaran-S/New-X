// Wonderland Wholesale Platform — Full Prisma Schema
// PostgreSQL 16 via Supabase

generator client {
  provider = "prisma-client-js"
  // "native" covers local dev; the arm64 target is required for the Raspberry Pi
  // (64-bit Raspberry Pi OS / Debian Bookworm ships OpenSSL 3.x).
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  MANAGER
  CASHIER
  WAREHOUSE
  SALES_REP
  DELIVERY
  BRAND_PRINCIPAL
  CUSTOMER
  WHOLESALE_BUYER
}

enum AccountType {
  RETAIL
  WHOLESALE
  STAFF
  VENDOR
}

enum UnitType {
  UNIT
  DOZEN
  CASE
  PALLET
}

enum OrderSource {
  POS
  WEBSITE
  WHATSAPP
  PHONE
  API
}

enum OrderStatus {
  PENDING
  PENDING_VERIFICATION
  CONFIRMED
  PROCESSING
  PRE_ORDER
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  UNPAID
  PENDING
  VERIFIED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  BANK_TRANSFER
  COD
  CREDIT_ACCOUNT
  CASH
  SPLIT
}

enum FulfillmentType {
  DELIVERY
  PICKUP
}

enum DeliveryProvider {
  PICKME_FLASH
  PRONTO
  OWN_FLEET
  PICKUP
}

enum VehicleType {
  MOTORBIKE
  TUK
  CAR
  TRUCK
}

enum ShipmentStatus {
  PENDING
  BOOKING
  ASSIGNED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  FAILED
}

enum ConvStatus {
  BOT
  HUMAN
  RESOLVED
}

enum Direction {
  INBOUND
  OUTBOUND
}

enum MsgType {
  TEXT
  IMAGE
  DOCUMENT
  AUDIO
  LIST
  BUTTON
  INTERACTIVE
}

enum AlertType {
  BACK_IN_STOCK
  PRE_ORDER
}

enum AdPlatform {
  META
  GOOGLE
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_DELIVERY
}

enum CouponScope {
  ALL
  WHOLESALE
  RETAIL
  SPECIFIC_PRODUCTS
}

enum LoyaltyTxType {
  EARN
  REDEEM
  BONUS
  EXPIRE
  ADJUST
}

// ─────────────────────────────────────────────
// USERS & AUTH
// ─────────────────────────────────────────────

model User {
  id                 String       @id @default(cuid())
  email              String?      @unique
  phone              String?      @unique
  whatsappPhone      String?
  name               String
  businessName       String?
  role               Role         @default(CUSTOMER)
  accountType        AccountType  @default(RETAIL)
  passwordHash       String?
  isActive           Boolean      @default(true)
  isApproved         Boolean      @default(false)

  // Credit & payment
  creditLimit        Decimal      @default(0) @db.Decimal(12, 2)
  outstandingBalance Decimal      @default(0) @db.Decimal(12, 2)
  paymentTermDays    Int          @default(0)

  // Pricing
  pricingTierId      String?
  pricingTier        PricingTier? @relation(fields: [pricingTierId], references: [id])

  // Loyalty & referral
  referralCode       String?      @unique
  referredById       String?
  referredBy         User?        @relation("Referrals", fields: [referredById], references: [id])
  referrals          User[]       @relation("Referrals")
  loyaltyPoints      Int          @default(0)

  // Analytics
  totalSpend         Decimal      @default(0) @db.Decimal(14, 2)
  orderCount         Int          @default(0)
  rfmScore           String?
  lastOrderAt        DateTime?

  // Timestamps
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  // Relations
  addresses                Address[]
  orders                   Order[]
  cart                     Cart?
  whatsappConversations    WhatsAppConversation[]
  loyaltyTransactions      LoyaltyTransaction[]
  auditLogs                AuditLog[]
  refreshTokens            RefreshToken[]
  salesRep                 SalesRep?
  brandPrincipal           BrandPrincipal?
  customerVisits           CustomerVisit[]
  verifiedPayments         Payment[]        @relation("VerifiedBy")
  processedOrders          Order[]          @relation("ProcessedBy")

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([rfmScore])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model Address {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  label       String?  // "Home", "Shop", "Warehouse"
  name        String
  phone       String
  line1       String
  line2       String?
  city        String
  district    String?
  postalCode  String?
  lat         Float?
  lng         Float?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  orders      Order[]

  @@index([userId])
}

// ─────────────────────────────────────────────
// PRODUCTS & INVENTORY
// ─────────────────────────────────────────────

model Brand {
  id              String           @id @default(cuid())
  name            String           @unique
  slug            String           @unique
  logoUrl         String?
  description     String?
  isActive        Boolean          @default(true)
  products        Product[]
  brandPrincipal  BrandPrincipal?
  createdAt       DateTime         @default(now())
}

model Category {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  parentId    String?
  parent      Category?  @relation("Subcategories", fields: [parentId], references: [id])
  children    Category[] @relation("Subcategories")
  iconUrl     String?
  imageUrl    String?
  sortOrder   Int        @default(0)
  isActive    Boolean    @default(true)
  products    Product[]
  createdAt   DateTime   @default(now())
}

model Tag {
  id       String    @id @default(cuid())
  name     String    @unique
  products Product[]
}

model Product {
  id              String           @id @default(cuid())
  sku             String           @unique
  barcode         String?          @unique
  name            String
  slug            String           @unique
  description     String?
  shortDescription String?
  brandId         String
  brand           Brand            @relation(fields: [brandId], references: [id])
  categoryId      String
  category        Category         @relation(fields: [categoryId], references: [id])
  images          ProductImage[]
  variants        ProductVariant[]
  pricingRules    PricingRule[]
  tags            Tag[]
  isActive        Boolean          @default(true)
  isFeatured      Boolean          @default(false)
  allowPreOrder   Boolean          @default(false)
  allowBackOrder  Boolean          @default(false)
  metaTitle       String?
  metaDescription String?
  sortOrder       Int              @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([slug])
  @@index([brandId])
  @@index([categoryId])
  @@index([isActive])
}

model ProductImage {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  alt       String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)
}

model ProductVariant {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku            String   @unique
  barcode        String?  @unique
  name           String   // "500ml", "1kg", "Blue"

  // Pricing (cost hidden from non-admin via CASL)
  costPrice      Decimal  @db.Decimal(10, 2)
  retailPrice    Decimal  @db.Decimal(10, 2)
  wholesalePrice Decimal  @db.Decimal(10, 2)

  // Physical dimensions — for vehicle selection algorithm
  lengthCm       Float
  widthCm        Float
  heightCm       Float
  weightGrams    Float
  unitsPerDozen  Int      @default(12)
  unitsPerCase   Int      @default(24)

  // Case box dimensions (auto-calculated if null using cubic root formula)
  caseLength     Float?
  caseWidth      Float?
  caseHeight     Float?
  caseWeightGrams Float?

  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  inventoryItems InventoryItem[]
  orderItems     OrderItem[]
  cartItems      CartItem[]
  stockAlerts    StockAlert[]

  @@index([productId])
  @@index([sku])
  @@index([barcode])
}

model Warehouse {
  id          String          @id @default(cuid())
  name        String
  address     String?
  isDefault   Boolean         @default(false)
  isActive    Boolean         @default(true)
  inventory   InventoryItem[]
}

model InventoryItem {
  id          String         @id @default(cuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  warehouseId String
  warehouse   Warehouse      @relation(fields: [warehouseId], references: [id])
  qty         Int            @default(0)
  reservedQty Int            @default(0)
  reorderLevel Int           @default(10)
  maxLevel    Int            @default(500)
  updatedAt   DateTime       @updatedAt

  @@unique([variantId, warehouseId])
  @@index([variantId])
}

model InventoryAdjustment {
  id          String   @id @default(cuid())
  variantId   String
  warehouseId String
  delta       Int      // positive = added, negative = removed
  reason      String   // "sale", "purchase", "damage", "count_correction", "return"
  reference   String?  // order number or PO number
  userId      String
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// PRICING ENGINE
// ─────────────────────────────────────────────

model PricingTier {
  id              String  @id @default(cuid())
  name            String  // "Retail", "Bronze", "Silver", "Gold", "Platinum"
  discountPct     Float   @default(0)
  minMonthlySpend Decimal @default(0) @db.Decimal(12, 2)
  sortOrder       Int     @default(0)
  isActive        Boolean @default(true)
  users           User[]
}

model PricingRule {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  unitType  UnitType
  minQty    Int      @default(1)
  price     Decimal  @db.Decimal(10, 2)
  label     String?  // "Per case (24 units)"
  isActive  Boolean  @default(true)

  @@unique([productId, unitType, minQty])
}

model Promotion {
  id            String      @id @default(cuid())
  name          String
  description   String?
  discountType  CouponType
  discountValue Decimal     @db.Decimal(10, 2)
  scope         CouponScope @default(ALL)
  productIds    String[]    // specific products (if SPECIFIC_PRODUCTS scope)
  minOrderAmt   Decimal     @default(0) @db.Decimal(10, 2)
  startsAt      DateTime
  endsAt        DateTime?
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
}

model Coupon {
  id           String      @id @default(cuid())
  code         String      @unique
  type         CouponType
  value        Decimal     @db.Decimal(10, 2)
  minOrderAmt  Decimal     @default(0) @db.Decimal(10, 2)
  maxUses      Int?
  usedCount    Int         @default(0)
  applicableTo CouponScope @default(ALL)
  productIds   String[]
  validFrom    DateTime
  validUntil   DateTime?
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
}

// ─────────────────────────────────────────────
// CART
// ─────────────────────────────────────────────

model Cart {
  id         String     @id @default(cuid())
  userId     String?    @unique
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionId  String?    @unique // for guest carts
  items      CartItem[]
  couponCode String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([sessionId])
}

model CartItem {
  id        String         @id @default(cuid())
  cartId    String
  cart      Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
  unitType  UnitType       @default(UNIT)
  qty       Int
  addedAt   DateTime       @default(now())

  @@unique([cartId, variantId, unitType])
}

// ─────────────────────────────────────────────
// ORDERS
// ─────────────────────────────────────────────

model Order {
  id                  String          @id @default(cuid())
  orderNumber         String          @unique // HP-2026-00001
  source              OrderSource
  customerId          String?
  customer            User?           @relation(fields: [customerId], references: [id])
  guestName           String?
  guestPhone          String?
  guestEmail          String?
  status              OrderStatus     @default(PENDING)
  paymentStatus       PaymentStatus   @default(UNPAID)
  fulfillmentType     FulfillmentType @default(DELIVERY)

  subtotal            Decimal         @db.Decimal(12, 2)
  discountAmount      Decimal         @default(0) @db.Decimal(12, 2)
  taxAmount           Decimal         @default(0) @db.Decimal(12, 2)
  deliveryAmount      Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount         Decimal         @db.Decimal(12, 2)

  couponCode          String?
  couponDiscount      Decimal         @default(0) @db.Decimal(12, 2)

  items               OrderItem[]
  payments            Payment[]
  shipment            Shipment?

  deliveryAddressId   String?
  deliveryAddress     Address?        @relation(fields: [deliveryAddressId], references: [id])
  deliveryNotes       String?

  // Staff who processed (POS)
  staffId             String?
  staff               User?           @relation("ProcessedBy", fields: [staffId], references: [id])

  // WhatsApp source
  whatsappConversationId String?

  // IRD compliance
  invoiceNumber       String?
  irdSubmittedAt      DateTime?

  notes               String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt

  @@index([orderNumber])
  @@index([customerId])
  @@index([status])
  @@index([source])
  @@index([createdAt])
}

model OrderItem {
  id         String         @id @default(cuid())
  orderId    String
  order      Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId  String
  variant    ProductVariant @relation(fields: [variantId], references: [id])
  unitType   UnitType
  qty        Int
  unitPrice  Decimal        @db.Decimal(10, 2)
  totalPrice Decimal        @db.Decimal(12, 2)
  discount   Decimal        @default(0) @db.Decimal(10, 2)
  costPrice  Decimal        @db.Decimal(10, 2) // snapshot — hidden from non-admin

  @@index([orderId])
  @@index([variantId])
}

// ─────────────────────────────────────────────
// PAYMENTS
// ─────────────────────────────────────────────

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  method          PaymentMethod
  status          PaymentStatus @default(PENDING)
  amount          Decimal       @db.Decimal(12, 2)
  referenceNo     String?       // bank transfer reference
  slipImageUrl    String?       // uploaded slip photo (Cloudflare R2)
  verifiedById    String?
  verifiedBy      User?         @relation("VerifiedBy", fields: [verifiedById], references: [id])
  verifiedAt      DateTime?
  codCollectedAt  DateTime?
  notes           String?
  createdAt       DateTime      @default(now())

  @@index([orderId])
  @@index([status])
}

// Inventory hold timer (BullMQ job reference)
model PaymentHold {
  id        String   @id @default(cuid())
  orderId   String   @unique
  jobId     String   // BullMQ job ID to cancel on payment verified
  expiresAt DateTime
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// DELIVERY & SHIPPING
// ─────────────────────────────────────────────

model Shipment {
  id                    String           @id @default(cuid())
  orderId               String           @unique
  order                 Order            @relation(fields: [orderId], references: [id])
  provider              DeliveryProvider
  providerRef           String?          // PickMe booking ID
  vehicleType           VehicleType
  trackingUrl           String?
  status                ShipmentStatus   @default(PENDING)
  estimatedFee          Decimal          @default(0) @db.Decimal(10, 2)
  actualFee             Decimal?         @db.Decimal(10, 2)
  pickedUpAt            DateTime?
  deliveredAt           DateTime?
  estimatedVolumeLitres Float?
  calculatedWeightKg    Float?
  failureReason         String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
}

// Vehicle capacity table — configurable in admin panel
model VehicleCapacity {
  id              String           @id @default(cuid())
  provider        DeliveryProvider
  vehicleType     VehicleType
  label           String           // "Flash (Motorbike)", "Flash L (Tuk-tuk)"
  maxWeightKg     Float
  maxVolumeLitres Float
  maxLengthCm     Float
  baseFee         Decimal          @db.Decimal(8, 2)
  perKmFee        Decimal          @db.Decimal(6, 2)
  isActive        Boolean          @default(true)

  @@unique([provider, vehicleType])
}

// ─────────────────────────────────────────────
// WHATSAPP MODULE
// ─────────────────────────────────────────────

model WhatsAppConversation {
  id            String               @id @default(cuid())
  remoteJid     String               // e.g. 94771234567@s.whatsapp.net
  customerPhone String
  customerId    String?
  customer      User?                @relation(fields: [customerId], references: [id])
  status        ConvStatus           @default(BOT)
  assignedToId  String?              // staff agent
  messages      WhatsAppMessage[]
  botState      Json?                // current bot flow state machine
  orderId       String?
  tags          String[]
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  @@unique([remoteJid])
  @@index([status])
  @@index([customerId])
}

model WhatsAppMessage {
  id             String               @id @default(cuid())
  conversationId String
  conversation   WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  messageId      String               @unique // Evolution API message ID
  direction      Direction
  type           MsgType
  content        String?
  mediaUrl       String?
  payload        Json                 // raw Evolution API payload
  sentAt         DateTime

  @@index([conversationId])
}

// ─────────────────────────────────────────────
// STOCK ALERTS & PRE-ORDERS
// ─────────────────────────────────────────────

model StockAlert {
  id          String         @id @default(cuid())
  variantId   String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  phone       String?
  email       String?
  userId      String?
  alertType   AlertType
  notifiedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@index([variantId])
}

// ─────────────────────────────────────────────
// LOYALTY & REFERRAL
// ─────────────────────────────────────────────

model LoyaltyTransaction {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        LoyaltyTxType
  points      Int           // positive = earn, negative = redeem/expire
  balance     Int           // points balance after this transaction
  orderId     String?
  description String?
  expiresAt   DateTime?
  createdAt   DateTime      @default(now())

  @@index([userId])
}

model Referral {
  id             String   @id @default(cuid())
  referrerId     String
  refereeId      String   @unique
  status         String   @default("pending") // pending | rewarded | expired
  rewardedAt     DateTime?
  referrerCredit Decimal  @default(0) @db.Decimal(10, 2)
  createdAt      DateTime @default(now())

  @@index([referrerId])
}

// ─────────────────────────────────────────────
// SALES REP CRM
// ─────────────────────────────────────────────

model SalesRep {
  id          String          @id @default(cuid())
  userId      String          @unique
  user        User            @relation(fields: [userId], references: [id])
  territory   String?
  isActive    Boolean         @default(true)
  visits      CustomerVisit[]
  routes      SalesRoute[]
}

model CustomerVisit {
  id          String    @id @default(cuid())
  salesRepId  String
  salesRep    SalesRep  @relation(fields: [salesRepId], references: [id])
  customerId  String
  customer    User      @relation(fields: [customerId], references: [id])
  lat         Float?
  lng         Float?
  notes       String?
  orderTaken  Boolean   @default(false)
  orderId     String?
  visitedAt   DateTime  @default(now())

  @@index([salesRepId])
  @@index([customerId])
}

model SalesRoute {
  id          String    @id @default(cuid())
  salesRepId  String
  salesRep    SalesRep  @relation(fields: [salesRepId], references: [id])
  date        DateTime
  stops       Json      // array of customer IDs in visit order
  status      String    @default("planned") // planned | active | completed
  createdAt   DateTime  @default(now())
}

// ─────────────────────────────────────────────
// VENDOR / BRAND PRINCIPAL PORTAL
// ─────────────────────────────────────────────

model BrandPrincipal {
  id               String  @id @default(cuid())
  brandId          String  @unique
  brand            Brand   @relation(fields: [brandId], references: [id])
  userId           String  @unique
  user             User    @relation(fields: [userId], references: [id])
  canViewSales     Boolean @default(true)
  canViewStock     Boolean @default(true)
  canViewRetailers Boolean @default(false)
}

// ─────────────────────────────────────────────
// DEMAND FORECASTING
// ─────────────────────────────────────────────

model DemandForecast {
  id           String   @id @default(cuid())
  variantId    String
  forecastDate DateTime
  predictedQty Int
  confidence   Float
  method       String   // "moving_avg", "seasonal", "trend", "ensemble"
  createdAt    DateTime @default(now())

  @@unique([variantId, forecastDate])
  @@index([variantId])
}

model RestockAlert {
  id           String   @id @default(cuid())
  variantId    String
  currentStock Int
  predictedDailyQty Float
  daysOfStock  Float
  isResolved   Boolean  @default(false)
  resolvedAt   DateTime?
  createdAt    DateTime @default(now())

  @@index([variantId])
}

// ─────────────────────────────────────────────
// ADS & MARKETING
// ─────────────────────────────────────────────

model AdConversionEvent {
  id        String     @id @default(cuid())
  platform  AdPlatform
  eventName String
  eventId   String     // for deduplication
  orderId   String?
  userId    String?
  value     Decimal?   @db.Decimal(12, 2)
  currency  String     @default("LKR")
  payload   Json
  success   Boolean
  sentAt    DateTime   @default(now())

  @@index([orderId])
  @@index([platform, eventName])
}

// ─────────────────────────────────────────────
// IRD COMPLIANCE
// ─────────────────────────────────────────────

model IrdSubmission {
  id          String   @id @default(cuid())
  orderId     String   @unique
  invoiceNo   String
  payload     Json     // what was sent to RAMIS API
  response    Json?    // API response
  status      String   @default("pending") // pending | submitted | failed
  attempts    Int      @default(0)
  submittedAt DateTime?
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// SYSTEM
// ─────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  action     String
  entityType String
  entityId   String
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model AppSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
