# ═══════════════════════════════════════════════════════════
# HealPlace API — Environment Variables
# Copy to .env and fill in your values
# LOCAL dev: defaults match docker-compose.yml at repo root
# ═══════════════════════════════════════════════════════════

# ── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://healplace:healplace_dev@localhost:5432/healplace?schema=public"

# Production — set automatically by Render Blueprint
# DATABASE_URL="postgresql://healplace:[PASSWORD]@[HOST].render.com/healplace"

# ── Redis ─────────────────────────────────────────────────
REDIS_URL="redis://:healplace_dev@localhost:6379"

# Production — Upstash (free tier at upstash.com)
# REDIS_URL="rediss://default:[TOKEN]@[HOST].upstash.io:6379"

# ── Meilisearch ───────────────────────────────────────────
MEILI_URL="http://localhost:7700"
MEILI_MASTER_KEY="healplace_meili_dev_key"

# Production — Meilisearch Cloud
# MEILI_URL="https://[PROJECT].meilisearch.io"
# MEILI_MASTER_KEY="[your-api-key]"

# ── JWT Auth ──────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_THIS_TO_A_LONG_RANDOM_STRING_IN_PRODUCTION"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="CHANGE_THIS_DIFFERENT_LONG_RANDOM_STRING"
JWT_REFRESH_EXPIRES_IN="30d"

# ── CORS — allowed frontend origins ──────────────────────
WEB_URL="http://localhost:3000"
POS_URL="http://localhost:3002"
ADMIN_URL="http://localhost:3003"

# Production
# WEB_URL="https://healplace.vercel.app"
# POS_URL="https://healplace-pos.vercel.app"
# ADMIN_URL="https://healplace-admin.vercel.app"

# ── Server ────────────────────────────────────────────────
NODE_ENV="development"
PORT=3001

# ── File Storage (Cloudflare R2) ──────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="healplace-uploads"
R2_PUBLIC_URL="https://uploads.healplace.lk"

# ── Email (Resend) ────────────────────────────────────────
RESEND_API_KEY=""
EMAIL_FROM="HealPlace <noreply@healplace.lk>"

# ── WhatsApp (Evolution API) ──────────────────────────────
EVOLUTION_API_URL="http://localhost:8080"
EVOLUTION_API_KEY=""
EVOLUTION_INSTANCE_NAME="healplace-main"

# ── Delivery — PickMe Flash ───────────────────────────────
PICKME_API_URL="https://api.pickme.lk/v1"
PICKME_API_KEY=""
SHOP_LAT="6.9349"
SHOP_LNG="79.8560"
SHOP_ADDRESS="Pettah, Colombo 11, Sri Lanka"

# ── Delivery — Pronto Lanka ───────────────────────────────
PRONTO_API_URL="https://api.pronto.lk/v1"
PRONTO_API_KEY=""

# ── Meta Conversions API (server-side) ───────────────────
META_PIXEL_ID=""
META_ACCESS_TOKEN=""

# ── Google Ads Enhanced Conversions ──────────────────────
GOOGLE_ADS_CONVERSION_ID=""
GOOGLE_ADS_API_KEY=""

# ── IRD RAMIS e-Invoicing ─────────────────────────────────
RAMIS_API_URL="https://api.ird.gov.lk/v1/invoices"
IRD_API_TOKEN=""
IRD_VAT_NUMBER=""
