# Meilisearch — Environment Variables
# Copy to .env and fill in real values before running docker-compose up -d

# ── Master Key ───────────────────────────────────────────────────────
# Required in production. Acts as the root key for generating API keys.
# Generate with: openssl rand -hex 32
MEILI_MASTER_KEY=your-meilisearch-master-key-here

# ── Environment ──────────────────────────────────────────────────────
# development: no auth required, search preview UI enabled at http://localhost:7700
# production:  auth required via MEILI_MASTER_KEY, no UI
MEILI_ENV=development

# ── Analytics ────────────────────────────────────────────────────────
# Disable telemetry (recommended for self-hosted)
MEILI_NO_ANALYTICS=true

# ── Logging ──────────────────────────────────────────────────────────
# Options: OFF, ERROR, WARN, INFO, DEBUG, TRACE
MEILI_LOG_LEVEL=INFO
