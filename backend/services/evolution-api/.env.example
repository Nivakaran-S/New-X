# Evolution API — Environment Variables
# Copy to .env and fill in real values before running docker-compose up -d

# ── Server ──────────────────────────────────────────────────────────
# Public URL where Evolution API is reachable (used in QR code links, webhooks)
SERVER_URL=http://localhost:8080

# ── Authentication ───────────────────────────────────────────────────
# API key required for all requests — generate a strong random string
AUTHENTICATION_API_KEY=your-evolution-api-key-here

# ── Database (optional, disabled by default for simple dev) ──────────
# Set to true to persist sessions across restarts using PostgreSQL
DATABASE_ENABLED=false
DATABASE_URL=postgresql://wonderland:wonderland_dev@localhost:5432/wonderland

# ── Redis (optional, disabled by default for simple dev) ─────────────
# Set to true to use Redis for caching/sessions
REDIS_ENABLED=false
REDIS_URL=redis://:wonderland_dev@localhost:6379

# ── Webhooks ─────────────────────────────────────────────────────────
# Where Evolution sends WhatsApp events (your Wonderland API endpoint)
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_GLOBAL_URL=http://your-wonderland-api:3001/webhooks/whatsapp

# ── WhatsApp Business API (if using Cloud API instead of Baileys) ────
WA_BUSINESS_TOKEN_WEBHOOK=
