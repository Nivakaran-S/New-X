# Chatwoot — Environment Variables
# Copy to .env and fill in real values before running docker-compose up -d

# ── Security ─────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
SECRET_KEY_BASE=your-secret-key-base-here-generate-with-openssl-rand-hex-64

# ── URLs ─────────────────────────────────────────────────────────────
# The public URL where Chatwoot will be accessible
FRONTEND_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────────
POSTGRES_USER=chatwoot
POSTGRES_PASSWORD=your-strong-postgres-password
POSTGRES_DB=chatwoot_production

# ── Redis ────────────────────────────────────────────────────────────
REDIS_PASSWORD=your-strong-redis-password

# ── Email / SMTP ─────────────────────────────────────────────────────
# Required for email notifications, password resets, conversation emails
MAILER_SENDER_EMAIL=noreply@wonderland.com
SMTP_DOMAIN=wonderland.com
SMTP_ADDRESS=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USERNAME=apikey
SMTP_PASSWORD=your-sendgrid-api-key
SMTP_AUTHENTICATION=plain
