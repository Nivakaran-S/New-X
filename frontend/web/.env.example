# ═══════════════════════════════════════════════════════════
# HealPlace Web Store — Environment Variables
# Copy to .env.local (Next.js ignores .env.local in git)
# ═══════════════════════════════════════════════════════════

# ── API connection ────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Production
# NEXT_PUBLIC_API_URL="https://healplace-api.onrender.com"

# ── Site URL (used in sitemap, OG tags, referral links) ──
NEXT_PUBLIC_WEB_URL="http://localhost:3000"

# Production
# NEXT_PUBLIC_WEB_URL="https://healplace.lk"

# ── Meta Pixel (client-side) ─────────────────────────────
NEXT_PUBLIC_META_PIXEL_ID=""

# ── Google Analytics 4 ───────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=""

# ── Google Places (address autocomplete in checkout) ─────
NEXT_PUBLIC_GOOGLE_PLACES_API_KEY=""
